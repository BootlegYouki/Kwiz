{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Kwiz",
  "version": "0.2.4",
  "identifier": "com.bootlegyouki.kwiz",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Kwiz",
        "width": 1280,
        "height": 720,
        "decorations": false,
        "dragDropEnabled": false,
        "maximized": true,
        "center": true,
        "backgroundColor": "#09090b",
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": false
  },
  "plugins": {}
}
