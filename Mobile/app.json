{
  "expo": {
    "name": "Kwiz",
    "slug": "kwiz",
    "version": "1.0.6",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "kwiz",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.bootlegyouki.kwiz",
      "icon": {
        "light": "./assets/icon.png",
        "dark": "./assets/icon.png",
        "tinted": "./assets/adaptive-icon-monochrome.png"
      },
      "infoPlist": {
        "CFBundleDocumentTypes": [
          {
            "CFBundleTypeName": "Kwiz File",
            "CFBundleTypeRole": "Viewer",
            "LSHandlerRank": "Owner",
            "LSItemContentTypes": [
              "com.bootlegyouki.kwiz"
            ]
          }
        ],
        "UTExportedTypeDeclarations": [
          {
            "UTTypeIdentifier": "com.bootlegyouki.kwiz",
            "UTTypeConformsTo": [
              "public.data"
            ],
            "UTTypeDescription": "Kwiz Quiz File",
            "UTTypeTagSpecification": {
              "public.filename-extension": [
                "kwiz"
              ]
            }
          }
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#121212",
        "foregroundImage": "./assets/adaptive-icon.png",
        "monochromeImage": "./assets/adaptive-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "intentFilters": [
        {
          "action": "VIEW",
          "categories": [
            "DEFAULT",
            "BROWSABLE"
          ],
          "data": [
            {
              "scheme": "file",
              "host": "*",
              "mimeType": "*/*",
              "pathPattern": ".*\\.kwiz"
            },
            {
              "scheme": "content",
              "host": "*",
              "mimeType": "*/*",
              "pathPattern": ".*\\.kwiz"
            }
          ]
        },
        {
          "action": "VIEW",
          "categories": [
            "DEFAULT",
            "BROWSABLE"
          ],
          "data": [
            {
              "scheme": "file",
              "host": "*",
              "mimeType": "*/*",
              "pathPattern": ".*\\.kwiz"
            },
            {
              "scheme": "content",
              "host": "*",
              "mimeType": "*/*",
              "pathPattern": ".*\\.kwiz"
            }
          ]
        }
      ],
      "versionCode": 6
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-font",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon-monochrome.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#F4F4F5",
          "dark": {
            "image": "./assets/splash-icon.png",
            "backgroundColor": "#18181B"
          }
        }
      ],
      "@react-native-community/datetimepicker"
    ]
  }
}
